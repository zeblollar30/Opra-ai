{
  "expo": {
    "name": "Opra",
    "slug": "opra",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "opra",
    "owner": "www.opra-ai.com",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.opraai.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.opraai.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-splash-screen",
      "expo-status-bar"
    ],
    "extra": {
      "eas": {
        "projectId": "f3b107ff-54ba-49b5-8088-44fbef03edc2"
      }
    }
  }
}
